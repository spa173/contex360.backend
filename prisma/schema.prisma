generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  active
  inactive
  pending
}

enum ThirdPartyKind {
  client
  provider
  employee
}

enum TaxRegime {
  simplificado
  comun
  especial
}

enum InvoiceStatus {
  draft
  emitted
  sent
  accepted
  cancelled
}

enum InventoryMovementType {
  entrada
  salida
}

enum InventoryTransferStatus {
  pendiente
  en_transito
  completado
  cancelado
}

enum PurchaseStatus {
  draft
  registered
  paid
  cancelled
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  CAJA
  BANCO
  PETTY_CASH
}

enum AuditSeverity {
  info
  warning
  error
  critical
}

enum DemoRequestStatus {
  nuevo
  contactado
  demo_agendada
  aprobado
  convertido
  cliente
  rechazado
}

model User {
  id                String                @id @default(cuid())
  name              String
  email             String                @unique
  status            UserStatus            @default(active)
  title             String
  lastLoginAt       DateTime?
  isDemoAccount     Boolean               @default(false)
  isSystemOwner     Boolean               @default(false)
  passwordHash      String?
  passwordSalt      String?
  deactivateAt      DateTime?
  reassignToUserId  String?
  policyAcceptedAt  DateTime?
  policyVersion     String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  memberships       Membership[]
  securityProfile   UserSecurityProfile?
  sessions          UserSession[]
  refreshTokens     RefreshToken[]
  inventoryMovements InventoryMovement[]
  invoicesOwned     Invoice[]             @relation("InvoiceOwner")
  auditEvents       AuditEvent[]          @relation("AuditActorUser")
  roleAccessHistory RoleAccessHistory[]    @relation("RoleAccessActorUser")
}

model Tenant {
  id                String                @id @default(cuid())
  name              String
  prefix            String                @unique
  nit               String?
  address           String?
  phone             String?
  allowNegativeStock Boolean               @default(false)
  sector            String?
  city              String?
  costMethod        String?
  dianStatus        String?
  securitySettings  Json
  invoicePrefix     String                @default("FV")
  lastInvoiceNumber Int                   @default(0)
  invoiceResolution String?
  resolutionFrom    DateTime?
  resolutionTo      DateTime?
  purchasePrefix    String                @default("CO")
  lastPurchaseNumber Int                  @default(0)
  dianEnvironment   String                @default("test") // test | production
  dianTestSetId     String?
  dianSoftwareId    String?
  dianSoftwarePin   String?
  dianCertificate   String?               // Base64 del certificado
  dianCertificatePassword String?
  dianNit           String?               // NIT para envío DIAN
  dianOperationCode String                 @default("10") // 10: factura ordinaria
  smtpHost          String?
  smtpPort          Int?
  smtpUser          String?
  smtpPassword      String?
  smtpFromEmail     String?
  activeIntegrations String[]               @default([])
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  memberships       Membership[]
  thirdParties      ThirdParty[]
  products          Product[]
  invoices          Invoice[]
  purchases         Purchase[]
  ledgerEntries     LedgerEntry[]
  inventoryMovements InventoryMovement[]
  inventoryTransfers InventoryTransfer[]
  ocrRuns           OcrRun[]
  userSessions      UserSession[]
  auditEvents       AuditEvent[]
  roleAccessHistory RoleAccessHistory[]
  subscription      Subscription?
  transactions       Transaction[]
  quotes             Quote[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model ThirdParty {
  id                      String         @id @default(cuid())
  tenantId                String
  name                    String
  nit                     String
  email                   String
  phone                   String?
  address                 String?
  city                    String?
  kind                    ThirdPartyKind
  taxProfile              String
  taxRegime               TaxRegime      @default(comun)
  fiscalResponsibilities  String[]       @default([])
  isActive                Boolean        @default(true)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  purchases Purchase[]
  quotes    Quote[]

  @@unique([tenantId, nit])
  @@index([tenantId, kind])
  @@index([tenantId, isActive])
}

model Product {
  id               String              @id @default(cuid())
  tenantId         String
  sku              String
  name             String
  price            Decimal             @db.Decimal(14, 2)
  cost             Decimal             @db.Decimal(14, 2)
  taxRate          Decimal             @db.Decimal(5, 2)
  stock            Int                 @default(0)
  stockByLocation  Json
  minStock         Int                 @default(0)
  maxStock         Int                 @default(0)
  location         String
  category         String
  barcode          String
  isInventoriable  Boolean             @default(true)
  productType      String
  kitComponents    Json?
  unit             String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceItems       InvoiceItem[]
  purchaseItems      PurchaseItem[]
  inventoryMovements InventoryMovement[]
  quoteItems         QuoteItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, category])
}

model Invoice {
  id             String         @id @default(cuid())
  tenantId       String
  clientId       String?
  ownerUserId    String?
  number         String         @default("")
  status         InvoiceStatus   @default(draft)
  subtotal       Decimal         @db.Decimal(14, 2)
  taxTotal       Decimal         @db.Decimal(14, 2)
  total          Decimal         @db.Decimal(14, 2)
  paymentTermDays Int            @default(30)
  notes          String?
  issuedAt       DateTime       @default(now())
  dueAt          DateTime?
  timeline       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   ThirdParty?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ownerUser User?       @relation("InvoiceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]
  transactions Transaction[]

  @@index([tenantId, status])
  @@index([tenantId, issuedAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  lineNumber  Int
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(14, 2)
  unitCost    Decimal  @db.Decimal(14, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([productId])
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  converted
}

model Quote {
  id             String      @id @default(cuid())
  tenantId       String
  clientId       String?
  number         String      @default("")
  status         QuoteStatus @default(draft)
  subtotal       Decimal     @db.Decimal(14, 2)
  taxTotal       Decimal     @db.Decimal(14, 2)
  total          Decimal     @db.Decimal(14, 2)
  validUntil     DateTime?
  notes          String?
  terms          String?
  convertedToInvoiceId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   ThirdParty? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items    QuoteItem[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  lineNumber  Int
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(14, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @db.Decimal(14, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
}

model Purchase {
  id             String         @id @default(cuid())
  tenantId       String
  providerId     String?
  number         String         @default("")
  status         PurchaseStatus @default(draft)
  subtotal       Decimal        @db.Decimal(14, 2)
  taxTotal       Decimal        @db.Decimal(14, 2)
  total          Decimal        @db.Decimal(14, 2)
  paymentTermDays Int           @default(30)
  notes          String?
  issuedAt       DateTime       @default(now())
  dueAt          DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider ThirdParty? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  items        PurchaseItem[]
  transactions Transaction[]

  @@index([tenantId, status])
  @@index([tenantId, issuedAt])
}

model PurchaseItem {
  id           String   @id @default(cuid())
  purchaseId   String
  productId    String?
  lineNumber   Int
  productName  String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(14, 2)
  taxRate      Decimal  @db.Decimal(5, 2)
  subtotal     Decimal  @db.Decimal(14, 2)
  taxAmount    Decimal  @db.Decimal(14, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchase Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([productId])
}

model LedgerEntry {
  id            String      @id @default(cuid())
  tenantId      String
  referenceType String
  referenceId   String?
  description   String
  amount        Decimal     @db.Decimal(14, 2)
  entryAt       DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines         LedgerLine[]

  @@index([tenantId, entryAt])
}

model LedgerLine {
  id            String      @id @default(cuid())
  ledgerEntryId String
  account       String
  label         String
  debit         Decimal     @db.Decimal(14, 2)
  credit        Decimal     @db.Decimal(14, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  ledgerEntry   LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)

  @@index([ledgerEntryId])
}

model InventoryMovement {
  id             String               @id @default(cuid())
  tenantId       String
  productId      String
  productName    String
  type           InventoryMovementType
  quantity       Int
  reason         String
  userId         String?
  batch          String
  expirationDate DateTime?
  note           String
  referenceId    String?
  attachmentUrl  String?
  at             DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([productId, at])
}

model InventoryTransfer {
  id         String                 @id @default(cuid())
  tenantId   String
  fromLocId  String
  toLocId    String
  status     InventoryTransferStatus @default(pendiente)
  quantity   Int
  receivedAt DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model OcrRun {
  id          String   @id @default(cuid())
  tenantId    String
  source      String
  sourcePreview String?
  fields      Json
  confidence  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model UserSecurityProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  twoFactorEnabled      Boolean  @default(false)
  twoFactorRequired     Boolean  @default(false)
  totpSecret            String?
  passwordResetRequired  Boolean  @default(false)
  passwordExpiryDays     Int?     @default(90)
  passwordUpdatedAt      DateTime?
  resetRequestedAt      DateTime?
  tempPasswordExpiresAt DateTime?
  riskLevel             String   @default("low")
  passwordHistory       Json
  failedLoginAttempts   Int      @default(0)
  lockedUntil           DateTime?
  trustedFingerprints   Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  ip         String
  location   String
  device     String
  browser    String
  os         String
  fingerprint String
  createdAt  DateTime @default(now())
  lastSeenAt DateTime
  revokedAt  DateTime?
  revokedBy  String?
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId])
  @@index([tenantId, revokedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  sessionId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model AuditEvent {
  id           String        @id @default(cuid())
  tenantId     String?
  entity       String
  action       String
  description  String
  at           DateTime      @default(now())
  actor        String
  actorUserId  String?
  severity     AuditSeverity @default(info)
  attachmentUrl String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([entity, action])
}

model RoleAccessHistory {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  actor     String
  actorUserId String?
  role      String
  moduleId  String
  permission String
  before    Boolean
  after     Boolean
  snapshot  Json
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("RoleAccessActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([role, moduleId, permission])
}

model DemoRequest {
  id        String            @id @default(cuid())
  nombre    String
  empresa   String
  correo    String
  telefono  String?
  mensaje   String?
  nit       String?
  ciudad    String?
  direccion String?
  sector    String?
  estado    DemoRequestStatus @default(nuevo)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([estado, createdAt])
}

model Transaction {
  id          String              @id @default(cuid())
  tenantId    String
  type        TransactionType
  amount      Decimal             @db.Decimal(14, 2)
  date        DateTime            @default(now())
  description String
  category    TransactionCategory @default(CAJA)
  reference   String?
  invoiceId   String?
  purchaseId  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice     Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  purchase    Purchase?           @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([tenantId, date])
  @@index([tenantId, type])
}

enum SupportTicketStatus {
  abierto
  en_proceso
  resuelto
  cerrado
}

enum SupportTicketPriority {
  baja
  media
  alta
  critica
}

model IntegrationCredential {
  id           String    @id @default(cuid())
  tenantId     String
  provider     String
  accountEmail String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model SupportTicket {
  id          String                @id @default(cuid())
  tenantId    String?
  userId      String?
  userName    String
  userEmail   String
  subject     String
  description String
  priority    SupportTicketPriority @default(media)
  status      SupportTicketStatus   @default(abierto)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([tenantId, createdAt])
}

model Subscription {
  id                String   @id @default(cuid())
  tenantId          String
  planType          String
  active            Boolean  @default(true)
  trialEndsAt       DateTime?
  renewsAt          DateTime?
  invoicesThisMonth Int      @default(0)

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
}

model HelpCategory {
  id        String        @id
  label     String
  icon      String
  articles  HelpArticle[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model HelpArticle {
  id         Int          @id @default(autoincrement())
  categoryId String
  title      String
  summary    String
  readTime   String
  icon       String
  steps      String[]
  category   HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([categoryId])
}

model HelpFaq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
