generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  active
  inactive
  pending
}

enum ThirdPartyKind {
  client
  provider
  employee
}

enum TaxRegime {
  simplificado
  comun
  especial
}

enum InvoiceStatus {
  draft
  emitted
  sent
  accepted
  cancelled
}

enum InventoryMovementType {
  entrada
  salida
}

enum InventoryTransferStatus {
  pendiente
  en_transito
  completado
  cancelado
}

enum PurchaseStatus {
  draft
  registered
  paid
  cancelled
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  CAJA
  BANCO
  PETTY_CASH
}

enum AuditSeverity {
  info
  warning
  error
  critical
}

enum DemoRequestStatus {
  nuevo
  contactado
  demo_agendada
  aprobado
  convertido
  cliente
  rechazado
}

model User {
  id                       String               @id @default(cuid())
  name                     String
  email                    String               @unique
  status                   UserStatus           @default(active)
  title                    String
  lastLoginAt              DateTime?
  isDemoAccount            Boolean              @default(false)
  isSystemOwner            Boolean              @default(false)
  passwordHash             String?
  passwordSalt             String?
  deactivateAt             DateTime?
  reassignToUserId         String?
  policyAcceptedAt         DateTime?
  policyVersion            String?
  privacyConsentAt         DateTime?
  privacyConsentVersion    String?
  termsAcceptedAt          DateTime?
  emailVerified            Boolean              @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  memberships              Membership[]
  securityProfile          UserSecurityProfile?
  sessions                 UserSession[]
  refreshTokens            RefreshToken[]
  inventoryMovements       InventoryMovement[]
  invoicesOwned            Invoice[]            @relation("InvoiceOwner")
  auditEvents              AuditEvent[]         @relation("AuditActorUser")
  roleAccessHistory        RoleAccessHistory[]  @relation("RoleAccessActorUser")
  consentimientos          Consentimiento[]
  solicitudesDerechos      SolicitudDerechos[]
  contratoAceptaciones     ContratoAceptacion[]
}

model Tenant {
  id                      String              @id @default(cuid())
  name                    String
  prefix                  String              @unique
  nit                     String?
  address                 String?
  phone                   String?
  allowNegativeStock      Boolean             @default(false)
  sector                  String?
  city                    String?
  costMethod              String?
  dianStatus              String?
  securitySettings        Json
  invoicePrefix           String              @default("FV")
  lastInvoiceNumber       Int                 @default(0)
  invoiceResolution       String?
  resolutionFrom          DateTime?
  resolutionTo            DateTime?
  purchasePrefix          String              @default("CO")
  lastPurchaseNumber      Int                 @default(0)
  dianEnvironment         String              @default("test") // test | production
  dianTestSetId           String?
  dianSoftwareId          String?
  dianSoftwarePin         String?
  dianCertificate         String? // Base64 del certificado
  dianCertificatePassword String?
  dianNit                 String? // NIT para env��o DIAN
  dianOperationCode       String              @default("10") // 10: factura ordinaria
  smtpHost                String?
  smtpPort                Int?
  smtpUser                String?
  smtpPassword            String?
  smtpFromEmail           String?
  activeIntegrations      String[]            @default([])
  adminSettings           Json                @default("{}")
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  onboardingCompletedAt   DateTime?
  memberships             Membership[]
  thirdParties            ThirdParty[]
  products                Product[]
  invoices                Invoice[]
  purchases               Purchase[]
  ledgerEntries           LedgerEntry[]
  inventoryMovements      InventoryMovement[]
  inventoryTransfers      InventoryTransfer[]
  ocrRuns                 OcrRun[]
  userSessions            UserSession[]
  auditEvents             AuditEvent[]
  roleAccessHistory       RoleAccessHistory[]
  subscription            Subscription?
  payments                Payment[]
  subscriptionInvoices    SubscriptionInvoice[]
  transactions            Transaction[]
  quotes                  Quote[]
  consentimientos         Consentimiento[]
  solicitudesDerechos     SolicitudDerechos[]
  contratos               Contrato[]
  contratoAceptaciones    ContratoAceptacion[]
  usageRecords            UsageRecord[]
  apiKeys                 ApiKey[]
  webhooks                Webhook[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model ThirdParty {
  id                     String         @id @default(cuid())
  tenantId               String
  name                   String
  nit                    String
  email                  String
  phone                  String?
  address                String?
  city                   String?
  kind                   ThirdPartyKind
  taxProfile             String
  taxRegime              TaxRegime      @default(comun)
  fiscalResponsibilities String[]       @default([])
  isActive               Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  purchases Purchase[]
  quotes    Quote[]

  @@unique([tenantId, nit])
  @@index([tenantId, kind])
  @@index([tenantId, isActive])
}

model Product {
  id              String   @id @default(cuid())
  tenantId        String
  sku             String
  name            String
  price           Decimal  @db.Decimal(14, 2)
  cost            Decimal  @db.Decimal(14, 2)
  taxRate         Decimal  @db.Decimal(5, 2)
  stock           Int      @default(0)
  stockByLocation Json
  minStock        Int      @default(0)
  maxStock        Int      @default(0)
  location        String
  category        String
  barcode         String
  isInventoriable Boolean  @default(true)
  productType     String
  kitComponents   Json?
  unit            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceItems       InvoiceItem[]
  purchaseItems      PurchaseItem[]
  inventoryMovements InventoryMovement[]
  inventoryTransfers InventoryTransfer[]
  quoteItems         QuoteItem[]

  @@unique([tenantId, sku])
  @@index([tenantId, category])
}

model Invoice {
  id              String        @id @default(cuid())
  tenantId        String
  clientId        String?
  ownerUserId     String?
  number          String        @default("")
  status          InvoiceStatus @default(draft)
  subtotal        Decimal       @db.Decimal(14, 2)
  taxTotal        Decimal       @db.Decimal(14, 2)
  total           Decimal       @db.Decimal(14, 2)
  paymentTermDays Int           @default(30)
  notes           String?
  issuedAt        DateTime      @default(now())
  dueAt           DateTime?
  timeline        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       ThirdParty?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  ownerUser    User?         @relation("InvoiceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]
  transactions Transaction[]

  @@index([tenantId, status])
  @@index([tenantId, issuedAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  lineNumber  Int
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(14, 2)
  unitCost    Decimal  @db.Decimal(14, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([productId])
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  converted
}

model Quote {
  id                   String      @id @default(cuid())
  tenantId             String
  clientId             String?
  number               String      @default("")
  status               QuoteStatus @default(draft)
  subtotal             Decimal     @db.Decimal(14, 2)
  taxTotal             Decimal     @db.Decimal(14, 2)
  total                Decimal     @db.Decimal(14, 2)
  validUntil           DateTime?
  notes                String?
  terms                String?
  convertedToInvoiceId String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client ThirdParty? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items  QuoteItem[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  lineNumber  Int
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(14, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @db.Decimal(14, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
}

model Purchase {
  id              String         @id @default(cuid())
  tenantId        String
  providerId      String?
  number          String         @default("")
  status          PurchaseStatus @default(draft)
  subtotal        Decimal        @db.Decimal(14, 2)
  taxTotal        Decimal        @db.Decimal(14, 2)
  total           Decimal        @db.Decimal(14, 2)
  paymentTermDays Int            @default(30)
  notes           String?
  issuedAt        DateTime       @default(now())
  dueAt           DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider     ThirdParty?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  items        PurchaseItem[]
  transactions Transaction[]
  ocrRun       OcrRun?

  @@index([tenantId, status])
  @@index([tenantId, issuedAt])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  productId   String?
  lineNumber  Int
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(14, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([productId])
}

model LedgerEntry {
  id            String    @id @default(cuid())
  tenantId      String
  referenceType String
  referenceId   String?
  description   String
  amount        Decimal   @db.Decimal(14, 2)
  reconciled    Boolean   @default(false)
  reconciledAt  DateTime?
  entryAt       DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  LedgerLine[]

  @@index([tenantId, entryAt])
  @@index([tenantId, reconciled])
}

model LedgerLine {
  id            String   @id @default(cuid())
  ledgerEntryId String
  account       String
  label         String
  debit         Decimal  @db.Decimal(14, 2)
  credit        Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ledgerEntry LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)

  @@index([ledgerEntryId])
}

model InventoryMovement {
  id             String                @id @default(cuid())
  tenantId       String
  productId      String
  productName    String
  type           InventoryMovementType
  quantity       Int
  reason         String
  userId         String?
  batch          String
  expirationDate DateTime?
  note           String
  referenceId    String?
  attachmentUrl  String?
  at             DateTime              @default(now())
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([productId, at])
}

model InventoryTransfer {
  id         String                  @id @default(cuid())
  tenantId   String
  productId  String
  fromLocId  String
  toLocId    String
  status     InventoryTransferStatus @default(pendiente)
  quantity   Int
  receivedAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([tenantId, status])
  @@index([productId])
}

model OcrRun {
  id                    String    @id @default(cuid())
  tenantId              String

  // Processing state
  status                String    @default("pending") // pending | processing | processed | failed

  // File metadata
  fileUrl               String    // Public URL (CDN or direct R2)
  storageKey            String?   // True R2/local key — source of truth for delete operations.
                                  // Null for records created before this field was added (P1-2).
                                  // Always set for new uploads; delete() falls back to urlToKey(fileUrl).
  sourcePreview         String?   // Thumbnail or preview URL
  mimeType              String?   // Real MIME type detected from magic bytes
  fileSizeBytes         Int?      // File size in bytes
  originalFileName      String?   // Sanitized original file name

  // Extraction result
  fields                Json      @default("{}")
  confidence            Float     @default(0)
  rawLlmResponse        String?   // Raw LLM text for debugging (truncated)

  // Error tracking
  errorMessage          String?
  retryCount            Int       @default(0)

  // Performance tracking
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?

  // Downstream links
  purchaseId            String?   @unique // Purchase draft created from this OCR run

  // Legacy field kept for compatibility
  source                String    @default("")

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model UserSecurityProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  twoFactorEnabled      Boolean   @default(false)
  twoFactorRequired     Boolean   @default(false)
  totpSecret            String?
  passwordResetRequired Boolean   @default(false)
  passwordExpiryDays    Int?      @default(90)
  passwordUpdatedAt     DateTime?
  resetRequestedAt      DateTime?
  tempPasswordExpiresAt DateTime?
  riskLevel             String    @default("low")
  passwordHistory       Json
  failedLoginAttempts   Int       @default(0)
  lockedUntil           DateTime?
  trustedFingerprints   Json
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String?
  ip          String
  location    String
  device      String
  browser     String
  os          String
  fingerprint String
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime
  revokedAt   DateTime?
  revokedBy   String?
  updatedAt   DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId])
  @@index([tenantId, revokedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  sessionId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model AuditEvent {
  id            String        @id @default(cuid())
  tenantId      String?
  entity        String
  action        String
  description   String
  at            DateTime      @default(now())
  actor         String
  actorUserId   String?
  severity      AuditSeverity @default(info)
  attachmentUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([entity, action])
}

model RoleAccessHistory {
  id          String   @id @default(cuid())
  at          DateTime @default(now())
  actor       String
  actorUserId String?
  role        String
  moduleId    String
  permission  String
  before      Boolean
  after       Boolean
  snapshot    Json
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("RoleAccessActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([role, moduleId, permission])
}

model DemoRequest {
  id        String            @id @default(cuid())
  nombre    String
  empresa   String
  correo    String
  telefono  String?
  mensaje   String?
  nit       String?
  ciudad    String?
  direccion String?
  sector    String?
  estado    DemoRequestStatus @default(nuevo)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([estado, createdAt])
}

model Transaction {
  id          String              @id @default(cuid())
  tenantId    String
  type        TransactionType
  amount      Decimal             @db.Decimal(14, 2)
  date        DateTime            @default(now())
  description String
  category    TransactionCategory @default(CAJA)
  reference   String?
  invoiceId   String?
  purchaseId  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice  Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([tenantId, date])
  @@index([tenantId, type])
}

enum SupportTicketStatus {
  abierto
  en_proceso
  resuelto
  cerrado
}

enum SupportTicketPriority {
  baja
  media
  alta
  critica
}

model IntegrationCredential {
  id           String    @id @default(cuid())
  tenantId     String
  provider     String
  accountEmail String?
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  metadata     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model SupportTicket {
  id          String                @id @default(cuid())
  tenantId    String?
  userId      String?
  userName    String
  userEmail   String
  subject     String
  description String
  priority    SupportTicketPriority @default(media)
  status      SupportTicketStatus   @default(abierto)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([tenantId, createdAt])
}

model Subscription {
  id                String    @id @default(cuid())
  tenantId          String
  planType          String
  billing           String    @default("monthly")
  active            Boolean   @default(true)
  trialEndsAt       DateTime?
  renewsAt          DateTime?
  cancelAt          DateTime?
  invoicesThisMonth Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments            Payment[]
  subscriptionInvoices SubscriptionInvoice[]

  @@unique([tenantId])
}

model Payment {
  id                String   @id @default(cuid())
  tenantId          String
  subscriptionId    String?
  wompiTransactionId String?  @unique
  amount            Int
  currency          String   @default("COP")
  status            String   @default("pending")
  paymentMethod     String?
  planType          String?
  billing           String?
  description       String?
  paidAt            DateTime?
  processedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription        Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  subscriptionInvoice SubscriptionInvoice?

  @@index([tenantId, createdAt])
}

model SubscriptionInvoice {
  id              String   @id @default(cuid())
  tenantId        String
  subscriptionId  String
  paymentId       String?  @unique
  invoiceNumber   String   @unique
  amount          Int
  tax             Int      @default(0)
  total           Int
  status          String   @default("pending")
  cufe            String?
  dianStatus      String?
  xmlFileName     String?
  timeline        Json?
  planType        String
  billing         String
  periodStart     DateTime
  periodEnd       DateTime
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payment      Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
}

model HelpCategory {
  id        String        @id
  label     String
  icon      String
  articles  HelpArticle[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model HelpArticle {
  id         Int          @id @default(autoincrement())
  categoryId String
  title      String
  summary    String
  readTime   String
  icon       String
  steps      String[]
  category   HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([categoryId])
}

model Consentimiento {
  id             String   @id @default(cuid())
  tenantId       String
  userId         String
  type           ConsentimientoTipo
  estado         ConsentimientoEstado @default(sinConsentir)
  version        String   @default("1.0")
  fecha          DateTime @default(now())
  ip             String?
  dispositivo    String?
  browser        String?
  hashConsent    String   @unique
  datosAdicionales Json?
  
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([tenantId, userId, type])
  @@index([type, estado])
}

enum ConsentimientoTipo {
  politicaPrivacidad
  terminosCondiciones
  marketingEmails
  analiticas
  cookies
  facturacion
  procesamientoDatos
}

enum ConsentimientoEstado {
  sinConsentir
  pendiente
  aceptado
  rechazado
  retirado
  actualizado
}

model SolicitudDerechos {
  id             String           @id @default(cuid())
  tenantId       String
  userId         String
  tipo           TipoSolicitudDerechos
  estado         SolicitudEstado   @default(recibida)
  fechaSolicitud DateTime         @default(now())
  fechaResolucion DateTime?
  solicitante    String
  emailSolicitante String
  ip             String?
  
  documentos     DocumentoDerechos[]
  comentarios    ComentarioDerechos[]
  
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([tenantId, tipo, estado])
  @@index([userId, fechaSolicitud])
}

enum TipoSolicitudDerechos {
  accesoDatos
  rectificacionDatos
  eliminacionDatos
  limitacionTratamiento
  portabilidadDatos
  oposicionTratamiento
  olvidoDigital
}

enum SolicitudEstado {
  recibida
  enProceso
  resuelta
  rechazada
  cancelada
}

model DocumentoDerechos {
  id             String   @id @default(cuid())
  solicitudId    String
  tipo           String
  archivoUrl     String
  hashArchivo    String
  fecha          DateTime @default(now())
  
  solicitud      SolicitudDerechos @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  
  @@index([solicitudId])
}

model ComentarioDerechos {
  id             String   @id @default(cuid())
  solicitudId    String
  comentario     String
  fecha          DateTime @default(now())
  usuarioId      String?
  
  solicitud      SolicitudDerechos @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  
  @@index([solicitudId])
}

model Contrato {
  id          String        @id @default(cuid())
  tenantId    String?
  tipo        TipoContrato
  version     String
  titulo      String
  cuerpo      String
  hash        String        @unique
  publicadoEn DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  aceptaciones ContratoAceptacion[]
  tenant       Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tipo, version])
  @@index([tenantId])
}

enum TipoContrato {
  terminosCondiciones
  politicaPrivacidad
  acuerdoSLA
  acuerdoProcesamientoDatos
  contratoServicio
  renovacionAutomatica
}

model ContratoAceptacion {
  id          String   @id @default(cuid())
  contratoId  String
  userId      String
  tenantId    String?
  firma       String   @unique
  ip          String?
  dispositivo String?
  geolocalizacion String?
  aceptadoEn  DateTime @default(now())

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([contratoId, userId])
  @@index([userId])
}

model HelpFaq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UptimeEvent {
  id             String   @id @default(cuid())
  status         String   // up | degraded | down
  responseTimeMs Int?
  error          String?
  checkedAt      DateTime @default(now())

  @@index([checkedAt])
  @@index([status, checkedAt])
}

model Incident {
  id          String    @id @default(cuid())
  title       String
  description String
  severity    String    // minor | major | critical
  status      String    @default("open") // open | investigating | resolved | closed
  startedAt   DateTime
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([startedAt])
}

model UsageRecord {
  id          String   @id @default(cuid())
  tenantId    String
  feature     String   // invoice_created | ai_query | ocr_run | email_sent | user_active
  quantity    Int      @default(1)
  recordedAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, feature, recordedAt])
  @@index([tenantId, recordedAt])
}

model ApiKey {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  key       String   @unique
  lastUsed  DateTime?
  expiresAt DateTime?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([tenantId])
}

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  url       String
  events    String[]
  active    Boolean  @default(true)
  secret    String?
  lastSent  DateTime?
  lastStatus String?
  retryCount Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
