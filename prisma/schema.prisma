generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  active
  inactive
  pending
}

enum ThirdPartyKind {
  client
  provider
}

enum InvoiceStatus {
  draft
  emitted
  sent
  accepted
  cancelled
}

enum InventoryMovementType {
  entrada
  salida
}

enum InventoryTransferStatus {
  pendiente
  en_transito
  completado
  cancelado
}

enum AuditSeverity {
  info
  warning
  error
  critical
}

enum DemoRequestStatus {
  nuevo
  contactado
  demo_agendada
  cliente
}

model User {
  id                String                @id @default(cuid())
  name              String
  email             String                @unique
  status            UserStatus            @default(active)
  title             String
  lastLoginAt       DateTime?
  isDemoAccount     Boolean               @default(false)
  isSystemOwner     Boolean               @default(false)
  passwordHash      String?
  passwordSalt      String?
  deactivateAt      DateTime?
  reassignToUserId  String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  memberships       Membership[]
  securityProfile   UserSecurityProfile?
  sessions          UserSession[]
  refreshTokens     RefreshToken[]
  inventoryMovements InventoryMovement[]
  auditEvents       AuditEvent[]          @relation("AuditActorUser")
  roleAccessHistory RoleAccessHistory[]    @relation("RoleAccessActorUser")
}

model Tenant {
  id                String                @id @default(cuid())
  name              String
  prefix            String                @unique
  allowNegativeStock Boolean               @default(false)
  sector            String?
  city              String?
  costMethod        String?
  dianStatus        String?
  securitySettings  Json
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  memberships       Membership[]
  thirdParties      ThirdParty[]
  products          Product[]
  invoices          Invoice[]
  ledgerEntries     LedgerEntry[]
  inventoryMovements InventoryMovement[]
  inventoryTransfers InventoryTransfer[]
  ocrRuns           OcrRun[]
  userSessions      UserSession[]
  auditEvents       AuditEvent[]
  roleAccessHistory RoleAccessHistory[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model ThirdParty {
  id         String         @id @default(cuid())
  tenantId   String
  name       String
  nit        String
  email      String
  kind       ThirdPartyKind
  taxProfile String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@unique([tenantId, nit])
  @@index([tenantId, kind])
}

model Product {
  id               String              @id @default(cuid())
  tenantId         String
  sku              String
  name             String
  price            Decimal             @db.Decimal(14, 2)
  cost             Decimal             @db.Decimal(14, 2)
  taxRate          Decimal             @db.Decimal(5, 2)
  stock            Int                 @default(0)
  stockByLocation  Json
  minStock         Int                 @default(0)
  maxStock         Int                 @default(0)
  location         String
  category         String
  barcode          String
  isInventoriable  Boolean             @default(true)
  productType      String
  kitComponents    Json?
  unit             String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceItems       InvoiceItem[]
  inventoryMovements InventoryMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId, category])
}

model Invoice {
  id             String         @id @default(cuid())
  tenantId       String
  clientId       String?
  status         InvoiceStatus   @default(draft)
  subtotal       Decimal         @db.Decimal(14, 2)
  taxTotal       Decimal         @db.Decimal(14, 2)
  total          Decimal         @db.Decimal(14, 2)
  paymentTermDays Int            @default(30)
  notes          String?
  issuedAt       DateTime       @default(now())
  dueAt          DateTime?
  timeline       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   ThirdParty?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items    InvoiceItem[]

  @@index([tenantId, status])
  @@index([tenantId, issuedAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  lineNumber  Int
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(14, 2)
  unitCost    Decimal  @db.Decimal(14, 2)
  taxRate     Decimal  @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(14, 2)
  taxAmount   Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([productId])
}

model LedgerEntry {
  id          String   @id @default(cuid())
  tenantId    String
  referenceType String
  referenceId String?
  description String
  amount      Decimal  @db.Decimal(14, 2)
  entryAt     DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entryAt])
}

model InventoryMovement {
  id             String               @id @default(cuid())
  tenantId       String
  productId      String
  productName    String
  type           InventoryMovementType
  quantity       Int
  reason         String
  userId         String?
  batch          String
  expirationDate DateTime?
  note           String
  referenceId    String?
  attachmentUrl  String?
  at             DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([productId, at])
}

model InventoryTransfer {
  id         String                 @id @default(cuid())
  tenantId   String
  fromLocId  String
  toLocId    String
  status     InventoryTransferStatus @default(pendiente)
  quantity   Int
  receivedAt DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model OcrRun {
  id          String   @id @default(cuid())
  tenantId    String
  source      String
  sourcePreview String?
  fields      Json
  confidence  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model UserSecurityProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  twoFactorEnabled      Boolean  @default(false)
  twoFactorRequired     Boolean  @default(false)
  totpSecret            String?
  passwordResetRequired  Boolean  @default(false)
  passwordExpiryDays     Int?     @default(90)
  passwordUpdatedAt      DateTime?
  resetRequestedAt      DateTime?
  tempPasswordExpiresAt DateTime?
  riskLevel             String   @default("low")
  passwordHistory       Json
  failedLoginAttempts   Int      @default(0)
  lockedUntil           DateTime?
  trustedFingerprints   Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  ip         String
  location   String
  device     String
  browser    String
  os         String
  fingerprint String
  createdAt  DateTime @default(now())
  lastSeenAt DateTime
  revokedAt  DateTime?
  revokedBy  String?
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId])
  @@index([tenantId, revokedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  sessionId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model AuditEvent {
  id           String        @id @default(cuid())
  tenantId     String?
  entity       String
  action       String
  description  String
  at           DateTime      @default(now())
  actor        String
  actorUserId  String?
  severity     AuditSeverity @default(info)
  attachmentUrl String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([entity, action])
}

model RoleAccessHistory {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  actor     String
  actorUserId String?
  role      String
  moduleId  String
  permission String
  before    Boolean
  after     Boolean
  snapshot  Json
  tenantId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUser User?   @relation("RoleAccessActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
  @@index([role, moduleId, permission])
}

model DemoRequest {
  id        String            @id @default(cuid())
  nombre    String
  empresa   String
  correo    String
  telefono  String?
  mensaje   String?
  estado    DemoRequestStatus @default(nuevo)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([estado, createdAt])
}

