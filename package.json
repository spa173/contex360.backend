{
  "name": "contex360-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "description": "NestJS backend for Contex360",
  "main": "dist/main.js",
  "scripts": {
    "dev": "vite",
    "start:dev": "vite",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "prisma generate",
    "start": "node --max-old-space-size=384 dist/main.js",
    "start:prod": "node --max-old-space-size=384 dist/main.js",
    "render:build": "NODE_OPTIONS='--max-old-space-size=450' npm install && NODE_OPTIONS='--max-old-space-size=450' npm run build",
    "db:setup": "node scripts/setup-dev-db.js",
    "db:stop": "node scripts/stop-dev-db.js",
    "db:migrate": "prisma migrate dev --name init",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.19.3",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^6.2.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "groq-sdk": "^1.2.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "node-forge": "^1.4.0",
    "nodemailer": "^8.0.7",
    "otplib": "^13.4.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "soap": "^1.9.2",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@prisma/config": "^7.8.0",
    "@swc/core": "^1.15.33",
    "@swc/helpers": "^0.5.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "@types/pdfkit": "^0.17.6",
    "@vitest/coverage-v8": "^4.1.5",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-node": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
