# =========================================================================
# Contex360 - Backend Git Ignore Configuration
# =========================================================================

# --- 1. SECRETS & TOKENS ---
# Evitar subir claves de API, contraseñas, certificados y configuraciones con credenciales
.env
.env.local
.env.*
**/*.pem
**/*.key
*.pub
*.cert
*.crt
*.pfx
*.p12
.npmrc
.yarnrc
auth.json
.git-credentials

# --- 2. AI AGENTS & TOOLS (Archivos de IA) ---
# Evitar subir configuraciones locales, permisos o historial de agentes de IA
# Nota: las reglas .claude/*.md SÍ se versionan (compartidas con el equipo).
#       Se ignora settings local, caché y worktrees del agente.
.claude/*
!.claude/*.md
.claude-cache/
.claude-worktree/
.claude-tmp/
.claudeignore
.gemini/
.gemini-cache/
.agents/
.adal/
.aider-desk/
.aider*
.augment/
.bob/
.codeartsdoer/
.codebuddy/
.codemaker/
.codestudio/
.commandcode/
.continue/
.cursor/
.cursor-cache/
.cursorrules
.cortex/
.crush/
.devin/
.factory/
.forge/
.goose/
.graphify/
.hermes/
.iflow/
.junie/
.kilocode/
.kimi/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.rovodev/
.tabnine/
.trae/
.vibe/
.windsurf/
.zencoder/
.windsurfrules
skills/
skills-lock.json
.skills/
.skill-cache/
.skill-temp/

# --- 3. LOCAL SETTINGS (Settings Locales) ---
# Configuraciones del IDE y archivos del sistema local/operativo
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/
.DS_Store
Thumbs.db
desktop.ini

# --- 4. LOGS (Registros) ---
# Logs de ejecución, depuración y del gestor de paquetes
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pnpm-error.log*

# --- 5. TEMPORARY FILES & BUILD OUTPUTS (Archivos Temporales) ---
# Cachés, dependencias instaladas y compilaciones de producción
node_modules/
dist/
coverage/
.pgdata/
.cache/
.turbo/
out/
tmp/
temp/
*.tmp
*.temp
tsconfig.tsbuildinfo
*.tsbuildinfo
*.bat
*.bak
*.backup
*.old

# Scripts y sandboxes temporales de desarrollo
scripts-temp/
tmp-scripts/
temp-scripts/
playground/
experiments/
prototypes/

# Reportes y salidas generadas (auditorías, benchmarks, código/docs generados)
reports/
audit-results/
performance-results/
benchmark-results/
generated/
generated-code/
generated-docs/

# Exports y bases de datos locales
exports/
downloads/
backup/
backups/
*.db
*.sqlite
*.sqlite3

# --- 6. PRIVATE CONTEXTS & LOCAL TESTING (Contextos Privados) ---
# Archivos de pruebas locales y notas de desarrollo personales
tests-local/
scratch/
_archive_scripts/
api-tests/
private-context/
prompts/
prompt-drafts/
contexts/
sandbox/
*.local