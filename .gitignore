# --- 3. LOCAL SETTINGS (Settings Locales) ---
# Configuraciones del IDE y archivos del sistema local/operativo
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/
.DS_Store
Thumbs.db

# --- 4. LOGS (Registros) ---
# Logs de ejecución, depuración y del gestor de paquetes
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pnpm-error.log*

# --- 5. TEMPORARY FILES & BUILD OUTPUTS (Archivos Temporales) ---
# Cachés, dependencias instaladas y compilaciones de producción
node_modules/
dist/
coverage/
.pgdata/
.cache/
.turbo/
out/
tmp/
temp/
*.tmp
*.temp
tsconfig.tsbuildinfo
*.tsbuildinfo
*.bat
*.bak

# --- 6. PRIVATE CONTEXTS & LOCAL TESTING (Contextos Privados) ---
# Archivos de pruebas locales y notas de desarrollo personales
tests-local/
scratch/
_archive_scripts/
api-tests/
private-context/
*.local