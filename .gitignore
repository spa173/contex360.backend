# =========================================================================
# Contex360 - Backend Git Ignore Configuration
# =========================================================================

# --- 1. SECRETS & TOKENS ---
# Evitar subir claves de API, contraseñas, certificados y configuraciones con credenciales
.env
.env.local
.env.*
**/*.pem
**/*.key
*.pub
*.cert
*.crt
*.pfx
*.p12
.npmrc
.yarnrc
auth.json
.git-credentials

# --- 2. AI AGENTS & TOOLS (Archivos de IA) ---
# Evitar subir configuraciones locales, permisos o historial de agentes de IA
.claude/
.claudeignore
.gemini/
.agents/
.adal/
.aider-desk/
.aider*
.augment/
