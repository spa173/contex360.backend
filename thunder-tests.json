{
  "version": "1.1",
  "collections": [
    {
      "name": "Contex360 Backend",
      "id": "contex360-backend",
      "variables": [
        { "key": "backendUrl", "value": "http://localhost:3000", "type": "text" },
        { "key": "email", "value": "user@example.com", "type": "text" },
        { "key": "password", "value": "password123", "type": "text" }
      ],
      "requests": [
        {
          "_id": "login-request",
          "name": "Login",
          "url": "{{backendUrl}}/auth/login",
          "method": "POST",
          "description": "Login al backend de Contex360 y guarda el access_token en la variable de entorno.",
          "headers": [
            { "enabled": true, "name": "Content-Type", "value": "application/json" }
          ],
          "body": {
            "type": "json",
            "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response JSON contains user.id', function () { pm.expect(response.user).to.have.property('id'); });",
                  "pm.environment.set('access_token', response.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "_id": "dashboard-request",
          "name": "Obtener Dashboard",
          "url": "{{backendUrl}}/analytics/dashboard",
          "method": "GET",
          "description": "Obtener KPIs del dashboard con token de acceso guardado automáticamente.",
          "headers": [
            { "enabled": true, "name": "Authorization", "value": "Bearer {{access_token}}" }
          ]
        },
        {
          "_id": "list-leads-request",
          "name": "Listar Leads",
          "url": "{{backendUrl}}/demo",
          "method": "GET",
          "description": "Lista los leads / solicitudes de demo del backend usando el token de acceso.",
          "headers": [
            { "enabled": true, "name": "Authorization", "value": "Bearer {{access_token}}" }
          ]
        }
      ]
    }
  ]
}
